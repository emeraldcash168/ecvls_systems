{
  "name": "vms-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "npm run dev:reset",
    "dev:stable": "npm run dev:reset:stable",
    "dev:reset": "node scripts/dev-reset.mjs && node -e \"console.log('\\nOpen web: http://localhost:3000/\\n')\" && next dev --turbopack --port 3000",
    "dev:reset:stable": "node scripts/dev-reset.mjs && node -e \"console.log('\\nOpen web: http://localhost:3000/\\n')\" && next dev --turbopack --port 3000",
    "dev:lan": "node scripts/dev-reset.mjs && next dev --turbopack --port 3000",
    "build": "next build",
    "start": "next start",
    "preview": "npm run build && next start",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 200",
    "typecheck": "next typegen && tsc --noEmit --pretty false",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify:ci": "npm run lint && npm run typecheck && npm run build && npm run audit:prod",
    "backup:create": "node scripts/backup-verification/create-vehicles-backup-table.mjs",
    "backup:verify": "node scripts/check-cleaned-table-data.mjs",
    "redis:check": "node scripts/check-redis.mjs",
    "db:check": "node scripts/test-neon-connection.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "d3-time-format": "^4.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.563.0",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.71.1",
    "react-player": "^3.4.0",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  },
  "type": "module"
}
