{
  "name": "vms-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:reset",
    "dev:stable": "npm run dev:reset:stable",
    "dev:reset": "node scripts/dev-reset.mjs && next dev --webpack --port 3000",
    "dev:reset:stable": "node scripts/dev-reset.mjs && FAST_REFRESH=false next dev --webpack --port 3000",
    "build": "next build --webpack",
    "start": "next start",
    "preview": "npm run build && next start",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 200",
    "test:db": "node scripts/test-neon-connection.mjs",
    "db:check": "node scripts/test-neon-connection.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/kv": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-time-format": "^4.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.71.1",
    "react-player": "^3.4.0",
    "recharts": "^3.7.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "playwright": "^1.48.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "type": "commonjs"
}
