# Neon PostgreSQL Database Connection
# Get this from your Neon console. Do not commit real credentials.
# Click "Connect" → "Database" to get your connection string

DATABASE_URL=postgresql://[username]:[password]@ep-[endpoint].us-east-1.aws.neon.tech/[database]?sslmode=require

# Example format (replace with your actual credentials):
# DATABASE_URL=postgresql://myuser:mypassword@ep-cool-river-123456.us-east-1.aws.neon.tech/mydb?sslmode=require

# Optional: Database connection settings
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000
DB_ENABLE_KEEPALIVE=true

# Redis cache / rate limit
# Vercel KV uses KV_REST_API_*.
# Upstash Redis Marketplace may provide UPSTASH_REDIS_REST_*; the app supports both.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Application settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NODE_ENV=development

# Authentication
# Generate a long random value for production: openssl rand -base64 48
SESSION_SECRET=
# Required only when a production database has no users yet.
INITIAL_ADMIN_PASSWORD=
# Comma-separated origins allowed to make credentialed mutation requests.
TRUSTED_ORIGINS=
# Comma-separated production hostnames allowed to serve the app.
ALLOWED_HOSTS=
# Secret request header added by Cloudflare before forwarding to Vercel.
CLOUDFLARE_ORIGIN_SECRET=
ENABLE_AUTH_DEBUG=false
ALLOW_HTTP_COOKIES=false

# Cloudflare Turnstile login protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
REQUIRE_TURNSTILE=false

# Backup verification
BACKUP_TABLE_NAME=cleaned_vehicles_for_google_sheets
EXPECTED_MAX_VEHICLE_ID=1222
ACTUAL_MAX_VEHICLE_ID=1190
BACKUP_SAMPLE_SIZE=3

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=vehicle_uploads
